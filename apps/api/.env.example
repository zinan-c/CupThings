DATABASE_URL=postgres://postgres:postgres@localhost:5432/cupthings
PORT=4000
WEB_ORIGIN=http://localhost:5173

# Use console for local development. Use smtp in production with SMTP_URL and EMAIL_FROM.
EMAIL_PROVIDER=console
SMTP_URL=
EMAIL_FROM=
COOKIE_SECURE=false

# Copy this file to .env.test for API tests and point it at a database ending in _test.
TEST_DATABASE_URL=postgres://postgres:postgres@localhost:5432/cupthings_test
