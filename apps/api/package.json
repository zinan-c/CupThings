{
  "name": "@cupthings/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "NODE_ENV=test tsx --test src/**/*.test.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@cupthings/shared": "workspace:*",
    "@fastify/cookie": "^11.1.2",
    "@fastify/cors": "^10.0.2",
    "@fastify/rate-limit": "^11.1.0",
    "drizzle-orm": "^0.38.3",
    "fastify": "^5.2.1",
    "nodemailer": "^9.0.3",
    "pg": "^8.13.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.30.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
